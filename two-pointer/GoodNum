import java.io.BufferedReader;
import java.io.IOException;
import java.io.InputStreamReader;
import java.util.Arrays;

public class GoodNum {
    public static void main(String[] args) throws IOException {

        BufferedReader br =new BufferedReader (new InputStreamReader(System.in));

        int input=Integer.parseInt(br.readLine());

        String input_string=br.readLine();

        String []string_arr=input_string.split(" ");

        int [] arr=new int[string_arr.length];

        for(int i=0;i<string_arr.length;i++){
            arr[i]=Integer.parseInt(string_arr[i]);
        }
        Arrays.sort(arr);
        int target=0;
        int start=0;
        int end=arr.length-1;

        int count=0;

        while(target<arr.length){
            if(start>=end){

                start=0;
                target++;
                end=arr.length-1;
                continue;
            }

            if(start==target){

                start++;
                continue;

            }
            if(end==target){

                end--;
                continue;
            }

            if(arr[start]+arr[end]==arr[target]){

                count++;

                start=0;
                target++;
                end=arr.length-1;

                continue;

            }else if(arr[start]+arr[end]<arr[target]){

                start++;

            } else if(arr[start]+arr[end]>arr[target]){

                end--;
            }


        }

        System.out.print(count);
    }
}
